DATABASE_URL=<server-only-postgres-url>
COMMAND_CENTER_OWNER_TOKEN=replace-with-a-long-random-owner-token
# B1 heartbeat: dedicated cron token (>=16 chars). Least-privilege — may ONLY POST
# /api/heartbeat/tick. Independent of the owner token; rotate/revoke on its own.
COMMAND_CENTER_CRON_TOKEN=replace-with-a-long-random-cron-token
# Optional: hour (ET) the daily heartbeat engines fire. Defaults to 6 (6am ET).
DAILY_RUN_HOUR_ET=6
# Optional per-engine autopilot seeds (default OFF). e.g. AUTOPILOT_AUTONOMY_CYCLE=false
# AUTOPILOT_AUTONOMY_CYCLE=false
# AUTOPILOT_SOURCES_DAILY=false
# AUTOPILOT_PUBLISHING_RUN=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=social-assets
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OAUTH_TOKEN_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CALENDAR_ID=
PRODUCT_EVENT_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_DRAFT_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=medium
ALLOW_LOCAL_IMAGE_FALLBACK=false
ANTHROPIC_API_KEY=
ANTHROPIC_DRAFT_MODEL=claude-opus-4-8
PUBLIC_APP_BASE_URL=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
ENABLE_LIVE_LINKEDIN_POSTING=false
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
ENABLE_LIVE_FACEBOOK_POSTING=false
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
ENABLE_LIVE_INSTAGRAM_POSTING=false
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
X_ACCESS_TOKEN=
ENABLE_LIVE_X_POSTING=false
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
ENABLE_LIVE_TIKTOK_POSTING=false
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_REDIRECT_URI=
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
ENABLE_LIVE_THREADS_POSTING=false
# B2 outreach (SendGrid). Live sending stays OFF until BOTH are set: OUTREACH_LIVE_SEND=true
# AND a real SENDGRID_API_KEY. Unset/false => every send is a dry_run (no network). The outreach
# engine also requires its autopilot toggle ON (default OFF), and fails closed on any
# classification with no mapped sequence (CSI = do-not-enroll). Go-live order for Roger: set the
# key, send a test to yourself, confirm, THEN flip the flag for real prospects.
SENDGRID_API_KEY=
OUTREACH_LIVE_SEND=false
# MVP reactivation (consumer B2C, SEPARATE from B2). Live sending stays OFF until
# REACTIVATION_LIVE_SEND=true AND a real SENDGRID_API_KEY, AND the reactivation engine autopilot is
# ON (default OFF), AND a wave is released. Reuses the same SendGrid client. Go-live order: import
# the list, run the seed test to REACTIVATION_SEED_RECIPIENTS, confirm render across clients, THEN
# flip the flag + autopilot and release Wave 1. REACTIVATION_SEED_RECIPIENTS = comma-separated
# operator addresses for the Day-0 seed (defaults to Roger's three: Gmail + legalease.com + the
# legalease.law Outlook alias). The seed refuses any address that appears in the consumer list.
REACTIVATION_LIVE_SEND=false
REACTIVATION_SEED_RECIPIENTS=roman.roger@gmail.com,roger@legalease.com,info@legalease.law
PORT=3001
APP_BASE_URL=
LOCAL_DEMO_MODE=true
STORAGE_BACKEND=json
SUPABASE_ANON_KEY=
SUPABASE_CORE_RECORDS_TABLE=leos_core_records
