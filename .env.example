# Local development defaults. Hosted production must use the Render secret store and
# passes the fail-closed checks documented in docs/secrets-and-env.md.
NODE_ENV=development
RENDER=false
HOST=127.0.0.1
PORT=3001
APP_BASE_URL=http://127.0.0.1:3001
APP_TIMEZONE=America/New_York

# Local JSON is never selected implicitly.
STORAGE_BACKEND=json
LOCAL_DEMO_MODE=true
COMMAND_CENTER_ALLOW_JSON=true
COMMAND_CENTER_DATA_PATH=/tmp/legalease-command-center-dev.json

# Hosted durable storage (leave blank locally).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CORE_RECORDS_TABLE=leos_core_records
SUPABASE_STORAGE_BUCKET=social-assets
SOCIAL_DRAFT_ASSETS_BUCKET=social-draft-assets-private

# Generate unique high-entropy values for every setting below. Bracketed examples are
# intentionally rejected by production readiness validation.
COMMAND_CENTER_OWNER_TOKEN=<generate-unique-owner-login-secret>
COMMAND_CENTER_ADMIN_TOKEN=<generate-unique-admin-login-secret>
COMMAND_CENTER_OPERATOR_TOKEN=<generate-unique-operator-login-secret>
COMMAND_CENTER_VIEWER_TOKEN=<generate-unique-viewer-login-secret>
COMMAND_CENTER_SESSION_SECRET=<generate-unique-session-hmac-secret>
COMMAND_CENTER_CRON_TOKEN=<generate-unique-cron-secret>
OAUTH_TOKEN_ENCRYPTION_KEY=<generate-unique-token-encryption-key>
OAUTH_STATE_SECRET=<generate-unique-oauth-state-secret>
ASSET_SIGNING_SECRET=<generate-unique-private-asset-signing-secret>

# Signed inbound routes.
SENDGRID_WEBHOOK_ENABLED=true
SENDGRID_WEBHOOK_PUBLIC_KEY=
PRODUCT_EVENT_WEBHOOK_ENABLED=true
PRODUCT_EVENT_WEBHOOK_SECRET=<generate-unique-product-event-secret>

# Provider credentials remain blank in development tests; provider calls are mocked.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=roman.roger@example.com
SENDGRID_REPLY_TO=roger@example.com
REACTIVATION_SEED_RECIPIENTS=info@example.com,synthetic@example.com,synthetic@example.com
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3001/api/google/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://127.0.0.1:3001/api/linkedin/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:3001/api/x/callback
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=http://127.0.0.1:3001/api/meta/callback

# Every outbound gate stays off by default.
ENABLE_LIVE_LINKEDIN_POSTING=false
ENABLE_LIVE_FACEBOOK_POSTING=false
ENABLE_LIVE_INSTAGRAM_POSTING=false
ENABLE_LIVE_X_POSTING=false
ENABLE_LIVE_THREADS_POSTING=false
ENABLE_LIVE_TIKTOK_POSTING=false
REACTIVATION_LIVE_SEND=false
OUTREACH_LIVE_SEND=false
ALERT_EMAIL_LIVE_SEND=false
PROSPECT_LIVE_DISCOVERY=false
ALLOW_LOCAL_IMAGE_FALLBACK=false
